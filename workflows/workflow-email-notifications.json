      "typeVersion": 2.1,
      "position": [1120, 400],
      "credentials": { "gmailOAuth2": { "name": "YOUR_GMAIL_CREDENTIAL_NAME" } }
    },
    {
      "parameters": {
        "sendTo": "={{ $json.user_email }}",
        "subject": "={{ $json.email_subject }}",
        "emailType": "html",
        "html": "={{ $json.email_html }}",
        "options": { "replyTo": "support@gracetools.com" }
      },
      "id": "email-0009",
      "name": "Send Email (Reset)",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [1120, 620],
      "credentials": { "gmailOAuth2": { "name": "YOUR_GMAIL_CREDENTIAL_NAME" } }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"sent\": true }",
        "options": {}
      },
      "id": "email-0010",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1340, 400]
    }
  ],
